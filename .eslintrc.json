{
  "extends": [
    "eslint:recommended",
    "plugin:mdx/recommended"
  ],
  "overrides": [
    {
      "files": ["*.mdx"],
      "extends": "plugin:mdx/recommended",
      "rules": {
        "no-unused-vars": "off",
        "no-undef": "off",
        "no-unused-expressions": "off"
      }
    }
  ],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  }
} 